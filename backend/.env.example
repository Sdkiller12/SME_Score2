# SME-Score Backend Environment Variables

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-at-least-32-characters

# QR Code HMAC Secret (min 32 chars)
QR_HMAC_SECRET=change-this-secret-in-production-min-32-characters

# Redis URL (Upstash)
REDIS_URL=redis://localhost:6379

# Model path
MODEL_PATH=./models/model_v1.pkl

# Allowed CORS origins
ALLOWED_ORIGINS=https://smescore.ci,http://localhost:3000
